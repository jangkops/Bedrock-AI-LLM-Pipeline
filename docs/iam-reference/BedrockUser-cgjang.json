    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {
          "AWS": [
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-Role4b6b39512d2a3b45-pzPIsiLYHDj7",
            "arn:aws:iam::<ACCOUNT_ID>:role/mogam-ora-RoleHeadNode-NoBedrock",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-RoleE023cc478a73ac4b-t59JrlvQNSsR",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-Role1582ca29d9c9c215-FRx5DLHFgTvv",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-Role1b671d0701297e71-9CrIDghINDOm",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-Role26b43a46ef83ef61-RORrNJQ4sEfQ",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-RoleHeadNode-s8E33tvp6ZW4",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-RoleFddf5a48e958cde0-PnbZiKu1235l",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-RoleD4a04feab6af0c39-NQldLulTWEGn",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-RoleE9d20843b98a0ad6-9o5EnlM6C07N",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-Role2b4fc89face312cf-QB5hBByjC2kI",
            "arn:aws:iam::<ACCOUNT_ID>:role/parallelcluster/mogam-ora/mogam-ora-ComputeFleetQueuesNe-Role1602693828933b93-n1B89PtIkP7n"
